#!/usr/bin/env bash
# .githooks/pre-commit — runs before each `git commit`.
#
# Activate by running `scripts/install-hooks.sh` once per clone, which sets
# `core.hooksPath` to `.githooks/`. Bypass with `--no-verify` (CI runs the same
# checks regardless). Cheap checks first, expensive last; fails fast.
#
#   File-level (always on):
#     1. Whitespace + missing-final-newline   (git diff --cached --check)
#     2. CRLF line endings in staged text files
#     3. Merge conflict markers in staged blobs
#     4. Large staged files (> 1 MB)
#
#   Trace-matrix parity (runs if the spec docs, the matrix, the generator, or
#   any test file are staged):
#     5. python scripts/build-trace-matrix.py --check
#
#   Python (skipped if no staged .py):
#     6. poetry run ruff check + ruff format --check
#     7. poetry run mypy src
#     8. poetry run pytest -q

set -euo pipefail

if [ -t 2 ]; then
    RED=$'\033[31m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'; RESET=$'\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; RESET=''
fi
step() { printf '%spre-commit:%s %s\n' "$YELLOW" "$RESET" "$1" >&2; }
fail() { printf '%spre-commit FAILED:%s %s\n' "$RED" "$RESET" "$1" >&2; exit 1; }
ok()   { printf '%spre-commit:%s %s\n' "$GREEN" "$RESET" "$1" >&2; }

cd "$(git rev-parse --show-toplevel)"

mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACM)
if (( ${#STAGED[@]} == 0 )); then
    ok "nothing staged"
    exit 0
fi

# ── 1. Whitespace + missing-final-newline ─────────────────────────────
step "git diff --cached --check (trailing whitespace, missing final newline)"
if ! git diff --cached --check; then
    fail "whitespace issues — fix and re-stage"
fi

# ── 2. CRLF line endings ──────────────────────────────────────────────
step "scanning for CRLF in staged text files"
crlf_files=()
for file in "${STAGED[@]}"; do
    case "$file" in
        *.png|*.jpg|*.jpeg|*.gif|*.ico|*.pdf|*.bin) continue ;;
    esac
    if git show ":$file" 2>/dev/null | grep -qU $'\r'; then
        crlf_files+=("$file")
    fi
done
if (( ${#crlf_files[@]} > 0 )); then
    printf '  %s\n' "${crlf_files[@]}" >&2
    fail "CRLF line endings detected. Convert to LF."
fi

# ── 3. Merge conflict markers ─────────────────────────────────────────
step "scanning for merge conflict markers"
conflict_files=()
for file in "${STAGED[@]}"; do
    if git show ":$file" 2>/dev/null | grep -nE '^(<{7}|={7}|>{7})( |$)' >/dev/null; then
        conflict_files+=("$file")
    fi
done
if (( ${#conflict_files[@]} > 0 )); then
    printf '  %s\n' "${conflict_files[@]}" >&2
    fail "merge conflict markers in staged content"
fi

# ── 4. Large staged files (> 1 MB) ────────────────────────────────────
step "checking staged file sizes (limit: 1 MB)"
LIMIT=$((1024 * 1024))
oversize=()
for file in "${STAGED[@]}"; do
    size=$(git cat-file -s ":$file" 2>/dev/null || echo 0)
    if (( size > LIMIT )); then
        oversize+=("$file ($size bytes)")
    fi
done
if (( ${#oversize[@]} > 0 )); then
    printf '  %s\n' "${oversize[@]}" >&2
    fail "files over 1 MB staged. Add to .gitignore or use git-lfs."
fi

# ── 5. Trace matrix parity ────────────────────────────────────────────
need_trace=0
for file in "${STAGED[@]}"; do
    case "$file" in
        tests/*.py|docs/L1-REQ.md|docs/L2-REQ.md|docs/L3-REQ.md|docs/TRACE-MATRIX.md|scripts/build-trace-matrix.py)
            need_trace=1; break ;;
    esac
done
if (( need_trace == 1 )); then
    step "python scripts/build-trace-matrix.py --check"
    if ! python scripts/build-trace-matrix.py --check; then
        fail "trace matrix out of date — run \`python scripts/build-trace-matrix.py\` and stage docs/TRACE-MATRIX.md"
    fi
fi

# ── Skip Python checks if no staged .py ───────────────────────────────
need_py=0
for file in "${STAGED[@]}"; do
    case "$file" in
        *.py) need_py=1; break ;;
    esac
done
if (( need_py == 0 )); then
    ok "file-level checks passed; no Python changes — skipping ruff/mypy/pytest"
    exit 0
fi

# ── 6. ruff ───────────────────────────────────────────────────────────
step "poetry run ruff check && ruff format --check"
if ! poetry run ruff check; then
    fail "ruff lint issues — run 'poetry run ruff check --fix'"
fi
if ! poetry run ruff format --check; then
    fail "formatting issues — run 'poetry run ruff format'"
fi

# ── 7. mypy ───────────────────────────────────────────────────────────
step "poetry run mypy src"
if ! poetry run mypy src; then
    fail "mypy type errors"
fi

# ── 8. pytest ─────────────────────────────────────────────────────────
step "poetry run pytest -q"
if ! poetry run pytest -q; then
    fail "tests failed"
fi

ok "all checks passed"
